# --- Server ---
PORT=3000

# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=freelancehub
DB_PASSWORD=freelancehub
DB_NAME=freelancehub

# --- Vector search (Qdrant) ---
QDRANT_URL=http://localhost:6333

# --- Embeddings (fastembed, in-process) ---
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# FASTEMBED_CACHE_DIR=./local_cache

# --- Resume parsing: PDF -> Markdown (LlamaCloud / LlamaParse) ---
# When unset, PDFs are parsed locally with pdf-parse instead.
LLAMA_CLOUD_API_KEY=
# LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai
# LLAMA_CLOUD_PARSE_MODE=parse_page_with_agent
# LLAMA_CLOUD_TIMEOUT_MS=120000

# --- Resume extraction: Markdown -> structured JSON (Groq) ---
# When unset, extraction falls back to heuristic keyword parsing.
GROQ_API_KEY=
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_RETRIES=3

# --- Legacy / self-hosted extractor (Ollama) ---
# Only used if ExtractionService is rebound to OllamaExtractionService.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EXTRACTION_MODEL=qwen2.5:3b
